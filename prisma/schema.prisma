generator client {
provider = "prisma-client"
output   = "../src/generated/prisma"
}

datasource db {
provider = "postgresql"
}

model User {
id         String   @id @default(cuid())
email      String   @unique
password   String
name       String?

accounts   Account[]
sessions   Session[]

portfolios Portfolio[]

createdAt  DateTime @default(now())
}

model Portfolio {
  id          String   @id @default(cuid())

  title       String
  slug        String   @unique
  template String @default("developer")
  data        Json

views PortfolioView[]

  published   Boolean  @default(false)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Account {
id                String @id @default(cuid())

userId            String

type              String
provider          String
providerAccountId String

refresh_token     String?
access_token      String?
expires_at        Int?
token_type        String?
scope             String?
id_token          String?
session_state     String?

user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

@@unique([provider, providerAccountId])
}

model Session {
id           String   @id @default(cuid())

sessionToken String   @unique

userId       String

expires      DateTime

user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
identifier String

token      String   @unique

expires    DateTime

@@unique([identifier, token])
}
model PortfolioView {
  id          String    @id @default(cuid())

  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id])

  createdAt   DateTime  @default(now())
}